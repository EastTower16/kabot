{
  "agents": {
    "defaults": {
      "workspace": "/Users/kothchen/.kabot/workspace",
      "model": "anthropic/claude-opus-4-5",
      "maxTokens": 8192,
      "temperature": 0.7,
      "maxToolIterations": 20
    },
    "instances": [
      {
        "name": "default"
      },
      {
        "name": "ops-agent",
        "workspace": "/Users/kothchen/.kabot/workspace/ops"
      }
    ]
  },
  "relay": {
    "defaults": {
      "host": "relay.example.com",
      "port": 443,
      "path": "/ws/agent",
      "useTls": true,
      "heartbeatIntervalS": 10,
      "reconnectInitialDelayMs": 1000,
      "reconnectMaxDelayMs": 15000
    },
    "managedAgents": [
      {
        "name": "default",
        "agentId": "agent-default",
        "token": "RELAY_AGENT_TOKEN"
      },
      {
        "name": "ops-agent",
        "agentId": "agent-ops",
        "token": "RELAY_OPS_TOKEN",
        "enabled": false
      }
    ]
  },
  "providers": {
    "openrouter": {
      "apiKey": "YOUR_OPENROUTER_KEY",
      "apiBase": "https://openrouter.ai/api/v1"
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "token": "8243851214:xxxx-xxx",
      "allowFrom": ["kothchen"],
      "binding": {
        "agent": "default"
      }
    }
  },
  "tools": {
    "web": {
      "search": {
        "apiKey": "YOUR_BRAVE_API_KEY"
      }
    }
  },
  "qmd": {
    "enabled": false,
    "command": "qmd",
    "collection": "kabot-memory",
    "maxResults": 5,
    "updateOnWrite": true,
    "updateEmbeddings": true
  },
  "heartbeat": {
    "enabled": true,
    "intervalS": 1800,
    "cronStorePath": "/Users/kothchen/.kabot/cron/jobs.json"
  },
  "logging": {
    "level": "info",
    "logFile": "/Users/kothchen/.kabot/logs/kabot.log",
    "enableStdout": true
  }
}
